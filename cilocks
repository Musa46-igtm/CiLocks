start_php_server() {
    local port="$1"
    local directory="${2:-.}"
    
    # Kill any existing PHP process on this port
    pkill -f "php.*${port}" 2>/dev/null || true
    sleep 1
    
    php -S "0.0.0.0:${port}" -t "${directory}" &>/dev/null &
    local pid=$!
    
    for i in {1..5}; do
        sleep 1
        if kill -0 "${pid}" 2>/dev/null && ss -tlnp 2>/dev/null | grep -q ":${port} "; then
            log_success "PHP server started on 0.0.0.0:${port} (PID ${pid})"
            return 0
        fi
        # Try checking differently
        if curl -s -o /dev/null -w "%{http_code}" "http://127.0.0.1:${port}/" 2>/dev/null | grep -q "200\|000"; then
            log_success "PHP server started on 0.0.0.0:${port}"
            return 0
        fi
    done
    
    log_error "Failed to start PHP server on port ${port}"
    return 1
}

