             grep -iv "${match_string}" | grep const-string | \
             sed 's/[^"]*"\([^"]*\)".*/\1/' | sort -u | \
             grep -v "Provided data must not be null.")

    if [[ ${#collections[@]} -gt 0 ]]; then
        log_success "Found ${#collections[@]} Firestore collection(s):"
        for c in "${collections[@]}"; do
