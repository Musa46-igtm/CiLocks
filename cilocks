wake_device() {
    adb shell input keyevent 26 2>/dev/null  # Power button
    sleep 0.5
    adb shell input keyevent 82 2>/dev/null  # Menu/Unlock
    sleep 0.5
}

swipe_unlock() {
    adb shell input swipe 540 1800 540 600 180 2>/dev/null
    sleep 0.5
}

get_device_resolution() {
    local disp
    disp=$(adb shell wm size 2>/dev/null | tr -d '\r' | head -1)
    SCREEN_WIDTH=$(echo "${disp}" | awk '{print $3}' | cut -dx -f1)
    SCREEN_HEIGHT=$(echo "${disp}" | awk '{print $3}' | cut -dx -f2)
    if [[ -z "${SCREEN_WIDTH}" ]]; then
        SCREEN_WIDTH=1080
        SCREEN_HEIGHT=1920
    fi
}

