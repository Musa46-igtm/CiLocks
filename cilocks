NGROK_CONFIG="/home/musa/Desktop/CiLocks/ngrok.yml"
NGROK_BIN="${SCRIPT_PATH}/ngrok"

get_network_info() {
    local default_iface
    default_iface=$(ip route | grep '^default' | awk '{print $5}' | head -n1 || true)

    if [[ -n "${default_iface}" ]]; then
        LAN_IP=$(ip -4 addr show dev "${default_iface}" | awk '/inet / {print $2}' | cut -d/ -f1 | head -n1 || true)
        [[ -z "${LAN_IP}" ]] && LAN_IP="Unknown"

        # Filter fe80 FIRST, take the top result SECOND, catch grep exit 1 with '|| true'
        LAN_IP6=$(ip -6 addr show dev "${default_iface}" | awk '/inet6 / {print $2}' | cut -d/ -f1 | grep -v '^fe80' | head -n1 || true)
        [[ -z "${LAN_IP6}" ]] && LAN_IP6="Unknown"
    else
        LAN_IP="Unknown"
        LAN_IP6="Unknown"
    fi

    PUBLIC_IP=$(dig +short myip.opendns.com @resolver1.opendns.com 2>/dev/null || curl -s --max-time 5 ifconfig.me 2>/dev/null || echo "Unknown")
}

download_ngrok() {
    if [[ -f "${NGROK_BIN}" ]]; then
        log_info "Ngrok already downloaded"
        return 0
    fi

    log_info "Downloading ngrok..."
    check_dependency "wget" "wget"
    check_dependency "tar" "tar"

    local arch
    arch=$(uname -m)
    local ngrok_url

    case "${arch}" in
        aarch64|arm64|armv8l)
            ngrok_url="https://bin.equinox.io/c/bNyj1mQVY4c/ngrok-v3-stable-linux-arm64.tgz"
            ;;
        armv7l|arm*)
            ngrok_url="https://bin.equinox.io/c/bNyj1mQVY4c/ngrok-v3-stable-linux-arm.tgz"
            ;;
        i386|i686|x86)
            ngrok_url="https://bin.equinox.io/c/bNyj1mQVY4c/ngrok-v3-stable-linux-386.tgz"
            ;;
        *)
            ngrok_url="https://bin.equinox.io/c/bNyj1mQVY4c/ngrok-v3-stable-linux-amd64.tgz"
            ;;
    esac

    # Explicitly bound to SCRIPT_PATH so it never dumps into the user's current working directory
    wget -q --show-progress "${ngrok_url}" -O "${SCRIPT_PATH}/ngrok.tgz"
    tar xzf "${SCRIPT_PATH}/ngrok.tgz" -C "${SCRIPT_PATH}"
    chmod +x "${NGROK_BIN}"
    rm -f "${SCRIPT_PATH}/ngrok.tgz"
    log_success "Ngrok downloaded successfully"
}

setup_ngrok_auth() {
    if [[ -f "${NGROK_CONFIG}" ]] && grep -q "authtoken" "${NGROK_CONFIG}" 2>/dev/null; then
        return 0
    fi
    # Just warn, don't fail — ngrok still works without auth for basic tunnels
    log_warn "ngrok v3 works best with an authtoken (free at https://dashboard.ngrok.com/signup)"
    log_warn "Set it with: ${NGROK_BIN} config add-authtoken YOUR_TOKEN --config ${NGROK_CONFIG}"
    return 0  # ← Changed from return 1 to return 0
}

get_ngrok_url() {
    local max_attempts=60
    local attempt=0
    local url=""

    while [[ $attempt -lt $max_attempts ]]; do
        # Primary: Local API parsed safely via python
        url=$(curl -s http://127.0.0.1:4040/api/tunnels 2>/dev/null | \
              python3 -c "import sys,json; d=json.load(sys.stdin); print(d['tunnels'][0]['public_url'])" 2>/dev/null || echo "")
        
        # Fallback 1: grep regex approach
        if [[ -z "${url}" ]]; then
            url=$(curl -s http://127.0.0.1:4040/api/tunnels 2>/dev/null | \
                  grep -oP '"public_url"\s*:\s*"\K[^"]+' | head -1)
        fi

        # Fallback 2: Status page scrape
        if [[ -z "${url}" ]]; then
            url=$(curl -s http://127.0.0.1:4040/status 2>/dev/null | \
                  grep -oP 'https://[a-zA-Z0-9_-]+\.ngrok[^"]+' | head -1)
        fi

        if [[ -n "${url}" ]]; then
            echo "${url}"
            return 0
        fi
        
        if (( attempt % 5 == 0 && attempt > 0 )); then
            echo -ne "\r${LIGHT_BLUE}[*] Waiting for ngrok... (${attempt}s)${NC}" >&2
        fi
        
        sleep 1
        ((attempt++))
    done
    
    echo "" >&2
    log_error "Failed to get ngrok URL after ${max_attempts} seconds"
    return 1
}

