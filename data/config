#!/usr/bin/env bash
m="\e[0;31m" # merah
k="\e[0;33m" # kuning
h="\e[0;32m" # hijau
b="\e[0;34m" # biru
lm="\e[1;31m" # merah terang
lk="\e[1;33m" # kuning terang
lh="\e[1;32m" # hijau terang
lb="\e[1;34m" # langit biru
n="\e[0m" # netral
w="\e[1;37m" # putih tebal

clear

# Check if metasploit is already installed
if command -v msfconsole &> /dev/null; then
    echo -e "${lh}[+] Metasploit is already installed.${n}"
else
    echo -e "${lk}[!] Metasploit not found. Installing...${n}"
    
    # Run the correct package installation
    # Using 'metasploit-framework' is the standard package name for Kali
    xterm -T "☣ INSTALLING METASPLOIT ☣" -geometry 100x30 -e "sudo apt-get update && sudo apt-get install metasploit-framework -y"
    
    # Verification
    if command -v msfconsole &> /dev/null; then
        echo -e "${lh}[+] Metasploit installed successfully.${n}"
    else
        echo -e "${lm}[-] Installation failed.${n}"
    fi
fi
